# Storyblok CMS — copy this file to ".env" and fill in. See STORYBLOK-SETUP.md.
# If these are blank, the site simply builds from models.json (nothing breaks).

# Read-only token used by the site build (Settings -> Access Tokens -> Preview/Public)
STORYBLOK_DELIVERY_TOKEN=

# Used ONCE by scripts/storyblok-setup.mjs (Account -> Personal access tokens)
STORYBLOK_MGMT_TOKEN=
# Numeric Space ID (Settings -> General)
STORYBLOK_SPACE_ID=

# Region hosts — defaults are EU. For a US space, switch both to the -us hosts:
#   STORYBLOK_CDN=https://api-us.storyblok.com
#   STORYBLOK_MAPI=https://api-us.storyblok.com/v1
STORYBLOK_CDN=https://api.storyblok.com
STORYBLOK_MAPI=https://mapi.storyblok.com/v1

# "published" for live content, or "draft" to preview unpublished edits
STORYBLOK_VERSION=published
